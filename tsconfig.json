{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "noEmitOnError": false
  },
  "include": [
    "index.ts",
    "setup-entry.ts",
    "channel-plugin-api.ts",
    "runtime-setter-api.ts",
    "secret-contract-api.ts",
    "setup-plugin-api.ts",
    "src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "_backups", "_trash", "tests"]
}
