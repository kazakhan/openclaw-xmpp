{
  "name": "@openclaw/xmpp",
  "version": "1.3.1",
  "description": "XMPP channel plugin for OpenClaw with file transfer and whiteboard support",
  "private": false,
  "type": "module",
  "main": "index.ts",
  "bin": {
    "openclaw-xmpp": "./cli-standalone.js"
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "xmpp",
      "label": "XMPP",
      "blurb": "XMPP/Jabber messaging via direct chat."
    },
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "echo \"Linting not configured\"",
    "typecheck": "npx tsc --noEmit index.ts --module es2020 --target es2020 --moduleResolution node"
  },
  "keywords": [
    "openclaw",
    "xmpp",
    "jabber",
    "chat",
    "plugin",
    "channel"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@xmpp/client": "^0.13.6",
    "ssh2": "^1.17.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3"
  }
}